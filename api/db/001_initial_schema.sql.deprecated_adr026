);

-- C4: Periodical Energy Quarterly (15-min intervals → hypertable)
CREATE TABLE trx_periodical_energy_quarterly (
    periodical_energy_quarterly_id BIGINT GENERATED ALWAYS AS IDENTITY,
    ecsu_id                 BIGINT REFERENCES fnd_ecsu(ecsu_id),
    meter_circuit_id        BIGINT,
    creation_date_group     TIMESTAMPTZ,
    quarter_seq             INTEGER,
    voltage                 NUMERIC,
    avg_electric_current    NUMERIC,
    frequency               NUMERIC,
    active_power            NUMERIC,
    power_factor            NUMERIC,
    thd                     NUMERIC,
    total_input_active_energy NUMERIC,
    active_power_demand     NUMERIC,
    prev_energy             NUMERIC,
    peak_energy_diff        NUMERIC,
    mid_peak_energy_diff    NUMERIC,
    off_peak_energy_diff    NUMERIC,
    price                   NUMERIC,
    energy_charge           NUMERIC,
    prev_creation_date      TIMESTAMPTZ,
    remark_desc             VARCHAR(500),
    creation_date           TIMESTAMPTZ DEFAULT NOW(),
    created_by              INTEGER,
    updated_at              TIMESTAMPTZ DEFAULT NOW(),
    updated_by              INTEGER,
    CONSTRAINT pk_trx_energy_quarterly PRIMARY KEY (periodical_energy_quarterly_id, creation_date)
);

SELECT create_hypertable('trx_periodical_energy_quarterly', 'creation_date',
    chunk_time_interval => INTERVAL '1 week');

-- C5: ECSU Tier Charge
CREATE TABLE trx_ecsu_tier_charge (
    ecsu_tier_charge_id     BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    ecsu_id                 BIGINT REFERENCES fnd_ecsu(ecsu_id),
    elec_billing_tier_id    BIGINT REFERENCES fnd_elec_billing_tier(elec_billing_tier_id),
    charge_date             TIMESTAMPTZ,
    kwh_usage               NUMERIC,
    charge_amount           NUMERIC,
    remark_desc             VARCHAR(500),
    creation_date           TIMESTAMPTZ DEFAULT NOW(),
    created_by              INTEGER,
    updated_at              TIMESTAMPTZ DEFAULT NOW(),
    updated_by              INTEGER
);

-- C6: Communication Success Rate Daily
CREATE TABLE trx_comm_success_rate_daily (
    circuit_cs_rate_daily_id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    modbus_device_circuit_id BIGINT REFERENCES fnd_modbus_device_circuit(modbus_device_circuit_id),
    rate_date               TIMESTAMPTZ,
    total_polls             INTEGER,
    success_polls           INTEGER,
    success_rate            NUMERIC,
    remark_desc             VARCHAR(500),
    creation_date           TIMESTAMPTZ DEFAULT NOW(),
    created_by              INTEGER,
    updated_at              TIMESTAMPTZ DEFAULT NOW(),
    updated_by              INTEGER
);

-- C7: Communication Abnormal Record
CREATE TABLE trx_comm_abn_record (
    comm_abn_record_id          BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
